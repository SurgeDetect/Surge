# ─── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ─────────────────────────────────────────────────────────────────
JUPITER_API_KEY=                # optional — increases rate limits

# ─── Spike Detection ─────────────────────────────────────────────────────────
SPIKE_THRESHOLD=3.0             # flag tokens with volume > 3x baseline
MIN_VOLUME_USD=50000            # ignore tokens below this volume
BASELINE_WINDOW_HOURS=24        # rolling window for baseline calc

# ─── Signals ─────────────────────────────────────────────────────────────────
MAX_SIGNALS_PER_CYCLE=5
MIN_CONFIDENCE=0.65

# ─── Scanner ─────────────────────────────────────────────────────────────────
SCAN_INTERVAL_MS=60000

# ─── Model ───────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
